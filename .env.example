# Copy this file to .env and adjust persistent settings for your machine. The
# Makefile loads .env automatically and provides workflow defaults. Override
# those defaults in .env or on the make command line only when needed. Never
# put AWS access keys or other credentials here.

# Experiment values shared by policy-setup, preflight, and managed launches.
DATASET=RoboDojo
TASK=general_pickup
ENV_CFG=bimanual_yam
SCENE=molmo_yam
ACTION_TYPE=joint
SEED=0
ENV_GPU=1

# Directory containing the XPolicyLab policy adapter.
POLICY_DIR=XPolicyLab/policy/Pi_05

# Policy runtime environment name or path.
POLICY_ENV=uv

# Checkpoint name or path passed to the policy adapter.
CKPT=pi05_yam_molmoact2

# Physical GPU used by the policy server.
POLICY_GPU=0

# `make eval` publishes completed results by default. Set false to keep runs
# local; direct `robodojo eval` requires an explicit --publish flag.
PUBLISH=true

# Writable local storage. Defaults to <repository>/.robodojo when unset.
ROBODOJO_STORAGE_ROOT=

# Dedicated S3 prefix used when publishing completed artifacts.
ROBODOJO_S3_URI=s3://your-bucket/robodojo

# Optional named AWS profile used by storage and Docker helpers.
AWS_PROFILE=

# RoboDojo diagnostics written to stderr: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
ROBODOJO_LOG_LEVEL=INFO
