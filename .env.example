# Copy this file to .env and adjust values for your machine. The Makefile loads
# .env automatically. Never put AWS access keys or other credentials here.

# Evaluation defaults
DATASET=RoboDojo
TASK=stack_bowls
ENV_CFG=arx_x5
SEED=0
ACTION_TYPE=ee
EXPERT_NUM=100
EVAL_NUM=1
POLICY_GPU=0
ENV_GPU=0

# Policy runtime (required by eval/server targets as noted by `make help`)
POLICY_DIR=
POLICY_NAME=
POLICY_ENV=
CKPT=
POLICY_HOST=127.0.0.1
POLICY_PORT=
BIND_HOST=0.0.0.0

# Downloads, results, and containers
DATA_TYPE=
EVAL_ROOT=eval_result/RoboDojo
IMAGE=robodojo:cuda12.8

# Durable read-only storage and local writable scratch
ROBODOJO_STORAGE_ROOT=
ROBODOJO_S3_URI=s3://your-bucket/robodojo
ROBODOJO_LOCAL_SCRATCH_ROOT=

# Optional read/work-root overrides
ROBODOJO_ASSETS_ROOT=
ROBODOJO_DATA_ROOT=
ROBODOJO_MODEL_ROOT=
ROBODOJO_CHECKPOINT_ROOT=
ROBODOJO_EVAL_ROOT=
ROBODOJO_EVAL_WORK_ROOT=
ROBODOJO_RUN_ROOT=
ROBODOJO_RUN_WORK_ROOT=

# Optional named AWS profile. Docker helpers mount ~/.aws read-only when present.
AWS_PROFILE=

# Set only after reviewing and accepting the Omniverse license terms.
OMNI_KIT_ACCEPT_EULA=

# Storage target inputs are normally supplied per command, for example:
# make storage-publish-dry-run \
#   STORAGE_SOURCE=/local/stage/payload \
#   STORAGE_RELATIVE=datasets/example
STORAGE_SOURCE=
STORAGE_DESTINATION=
STORAGE_RELATIVE=
STORAGE_KIND=
STORAGE_POLICY=
STORAGE_CHECKPOINT=
