# Copy this file to .env and adjust persistent settings for your machine. The
# Makefile loads .env automatically and provides workflow defaults. Override
# those defaults in .env or on the make command line only when needed. Never
# put AWS access keys or other credentials here.

# Common evaluation inputs required by eval and server targets.
POLICY_DIR=
POLICY_ENV=
CKPT=

# Optional when commands are run outside the checkout.
ROBODOJO_ROOT=

# Durable read-only storage and local writable scratch
ROBODOJO_STORAGE_ROOT=
ROBODOJO_S3_URI=s3://your-bucket/robodojo
ROBODOJO_LOCAL_SCRATCH_ROOT=

# Optional read/work-root overrides
ROBODOJO_ASSETS_ROOT=
ROBODOJO_DATA_ROOT=
ROBODOJO_MODEL_ROOT=
ROBODOJO_CHECKPOINT_ROOT=
ROBODOJO_EVAL_ROOT=
ROBODOJO_EVAL_WORK_ROOT=
ROBODOJO_RUN_ROOT=
ROBODOJO_RUN_WORK_ROOT=

# Optional named AWS profile. Docker helpers mount ~/.aws read-only when present.
AWS_PROFILE=

# Omniverse license acceptance for non-interactive simulator commands.
OMNI_KIT_ACCEPT_EULA=yes
